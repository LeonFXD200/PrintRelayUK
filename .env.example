# ===========================================================================
# PrintRelay UK — environment variables
# ---------------------------------------------------------------------------
# Copy this file to `.env` and fill in values to enable LIVE mode. If left
# blank (or the file is absent) the app runs in DEMO / MOCK mode: enquiries are
# stored in your browser's localStorage, no network calls are made, no emails
# are sent. Nothing here is required to run or test the site.
#
# Only variables prefixed with VITE_ are exposed to the browser by Vite.
#
# ⚠️  NEVER put a secret in a VITE_ variable or in frontend code or in git:
#     the service-role key, Resend API key and Turnstile SECRET are server-only.
#     They live ONLY as Supabase Edge Function secrets (see the block at the
#     bottom). The browser only ever uses the anon key + the public site key.
# ===========================================================================

# ---- Supabase (browser-safe) ----------------------------------------------
# From Supabase dashboard → Project Settings → API. The anon key is designed to
# be public; Row Level Security is what protects your data.
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# ---- Cloudflare Turnstile (browser-safe) — REQUIRED for live mode ----------
# PUBLIC site key only. When set, the quote form shows the challenge and the
# Edge Function verifies it server-side before storing anything. The function
# FAILS CLOSED by default (REQUIRE_TURNSTILE=true), so do NOT enable live mode
# until this and the function's TURNSTILE_SECRET_KEY are both configured.
VITE_TURNSTILE_SITE_KEY=

# ===========================================================================
# SERVER-SIDE SECRETS — do NOT add these here or to any VITE_ variable.
# Set them on the Edge Function instead:
#   supabase secrets set RESEND_API_KEY=re_xxx \
#     ENQUIRY_FROM_EMAIL="PrintRelay UK <quotes@yourdomain.co.uk>" \
#     ENQUIRY_NOTIFY_EMAIL=you@yourdomain.co.uk \
#     TURNSTILE_SECRET_KEY=0x_your_secret \
#     REQUIRE_TURNSTILE=true
#
#   RESEND_API_KEY              Resend API key (sends the emails). Omit = no email.
#   ENQUIRY_FROM_EMAIL          Verified "from" address for outgoing email.
#   ENQUIRY_NOTIFY_EMAIL        Inbox that receives new-enquiry notifications.
#   TURNSTILE_SECRET_KEY        Cloudflare Turnstile secret (verifies tokens).
#   REQUIRE_TURNSTILE           Bot protection FAILS CLOSED. Defaults to "true":
#                               if true and Turnstile isn't configured (or a
#                               request has no valid token), the enquiry is
#                               REJECTED before anything is stored. Set to
#                               "false" only to deliberately run without it.
#
# ⚠️  DO NOT enable live mode unless Turnstile is configured. With the default
#     REQUIRE_TURNSTILE=true and no TURNSTILE_SECRET_KEY, every submission is
#     rejected on purpose (fail closed).
#
# SUPABASE_URL and SUPABASE_SERVICE_ROLE_KEY are injected into Edge Functions
# automatically by Supabase — you do NOT set them, and they never touch the
# browser.
# ===========================================================================
