# PrintRelay UK — environment variables
#
# Copy this file to `.env` and fill in real values to enable Supabase mode.
# If these are left blank or the file is absent, the app automatically runs in
# DEMO / MOCK mode (local sample data, demo logins, no network calls).
#
# Vite only exposes variables prefixed with VITE_ to the browser.

# Your Supabase project URL, e.g. https://abcdefgh.supabase.co
VITE_SUPABASE_URL=

# Your Supabase anon/public key (safe to expose in a client app)
VITE_SUPABASE_ANON_KEY=
